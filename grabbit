#!/usr/bin/env bash
# grabbit — cross-distro package grabber and restorer
# Saves/restores explicitly installed packages (excluding distro base) + external sources (AUR, Homebrew)
# Supports command transposition across distros (apt <-> pacman etc.)
#
# Usage:
#   grabbit save <file>                 Save list of added packages to proprietary file
#   grabbit -x save <file>              Extended save (same as above for now; use -x types to filter)
#   grabbit load <file>                 Restore/install from proprietary file using current distro tools
#   grabbit -x load <file>              Load while skipping certain types
#
#   grabbit -x aur,brew save mylist.grab   # exclude aur and brew when saving
#   grabbit -x aur load mylist.grab        # ignore aur packages on load
#
# The file at PATH is grabbit's proprietary format containing origin info + package list.

set -euo pipefail

# ── colors & formatting (like rack) ───────────────────────────────────────────
if [[ -t 1 ]]; then
  BOLD="\033[1m"
  DIM="\033[2m"
  GREEN="\033[1;32m"
  YELLOW="\033[1;33m"
  CYAN="\033[1;36m"
  RED="\033[1;31m"
  RESET="\033[0m"
else
  BOLD="" DIM="" GREEN="" YELLOW="" CYAN="" RED="" RESET=""
fi

# ── helpers ───────────────────────────────────────────────────────────────────
usage() {
  echo -e "${BOLD}grabbit${RESET} — save and restore packages across any Linux distro"
  echo ""
  echo -e "${BOLD}Usage:${RESET}"
  echo -e "  grabbit ${CYAN}save${RESET} <file>                    Save user-added packages (excludes distro base)"
  echo -e "  grabbit ${CYAN}-sp save${RESET} <file>                Save including distro/system packages"
  echo -e "  grabbit ${CYAN}-x save${RESET} <file>                 Extended save (or filter with types)"
  echo -e "  grabbit ${CYAN}load${RESET} <file>                    Install packages from a grabbit file"
  echo -e "  grabbit ${CYAN}-x load${RESET} <file>                 Load while skipping specified types"
  echo -e "  grabbit ${CYAN}install${RESET} [--skip-deps]         Install/update global CLI+GUI and distro deps"
  echo ""
  echo -e "${BOLD}Filter examples:${RESET}"
  echo -e "  grabbit ${CYAN}-x aur,brew save${RESET} my.grab        # do not include AUR or Homebrew packages"
  echo -e "  grabbit ${CYAN}-x aur load${RESET} my.grab             # skip AUR packages during restore"
  echo ""
  echo -e "  -x acts as modifier: when followed by comma-separated types (aur,brew,base) it skips them."
  echo -e "  When used as 'grabbit -x save' without types it performs a full extended capture."
  echo ""
  echo -e "${BOLD}Features:${RESET}"
  echo -e "  • Detects distro and uses correct package manager syntax automatically"
  echo -e "  • Transposes commands when loading a file created on a different distro (apt ↔ pacman etc.)"
  echo -e "  • Uses paru for AUR packages (auto-installs paru if needed on Arch)"
  echo -e "  • Auto-installs package managers/helpers (Homebrew, paru, snapd, flatpak) if referenced"
  echo -e "  • Excludes most distro base packages by using explicit/manual install lists + heuristics"
  echo -e "  • When a package name matches multiple sources (mainline vs AUR etc.) on load: prompts you to choose (interactive only)"
  echo ""
  echo -e "File created by save is self-contained and contains everything needed for load."
  exit 1
}

die() {
  echo -e "\n${RED}✖ error:${RESET} $*" >&2
  exit 1
}

step() {
  echo -e "\n${CYAN}::${RESET} ${BOLD}$*${RESET}"
}

info() {
  echo -e "   ${DIM}$*${RESET}"
}

ok() {
  echo -e "   ${GREEN}✔${RESET} $*"
}

warn() {
  echo -e "   ${YELLOW}⚠${RESET}  $*"
}

_pick_option() {
  local prompt="$1"; shift
  local -a items=("$@")
  local i=1 choice
  for item in "${items[@]}"; do
    printf "   ${CYAN}%3d)${RESET}  %s\n" "$i" "$item"
    ((i++))
  done
  echo ""
  while true; do
    printf "   ${BOLD}%s${RESET} " "$prompt"
    read -r choice < /dev/tty || choice=""
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= ${#items[@]} )); then
      echo "${items[$((choice-1))]}"
      return 0
    fi
    warn "Enter a number between 1 and ${#items[@]}."
  done
}

# ── configuration ─────────────────────────────────────────────────────────────
GRABBIT_VERSION="1"
SUPPORTED_FAMILIES=(debian arch fedora suse alpine)

# ── distro detection ──────────────────────────────────────────────────────────
detect_distro() {
  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    . /etc/os-release
  fi

  DISTRO_ID="${ID:-unknown}"
  DISTRO_NAME="${NAME:-Unknown}"
  DISTRO_VERSION="${VERSION_ID:-}"

  case "$DISTRO_ID" in
    debian|ubuntu|linuxmint|pop|elementary|kali|raspbian)
      FAMILY="debian"
      PM="apt"
      INSTALL_CMD="sudo apt update && sudo apt install -y"
      ;;
    arch|manjaro|endeavouros|garuda|artix)
      FAMILY="arch"
      PM="pacman"
      INSTALL_CMD="sudo pacman -S --needed --noconfirm"
      ;;
    fedora|centos|rhel|rocky|almalinux)
      FAMILY="fedora"
      PM="dnf"
      INSTALL_CMD="sudo dnf install -y"
      ;;
    opensuse*|suse)
      FAMILY="suse"
      PM="zypper"
      INSTALL_CMD="sudo zypper install -y"
      ;;
    alpine)
      FAMILY="alpine"
      PM="apk"
      INSTALL_CMD="sudo apk add"
      ;;
    *)
      # Fallback detection by available commands
      if command -v apt >/dev/null 2>&1; then
        FAMILY="debian"; PM="apt"; INSTALL_CMD="sudo apt update && sudo apt install -y"
      elif command -v pacman >/dev/null 2>&1; then
        FAMILY="arch"; PM="pacman"; INSTALL_CMD="sudo pacman -S --needed --noconfirm"
      elif command -v dnf >/dev/null 2>&1; then
        FAMILY="fedora"; PM="dnf"; INSTALL_CMD="sudo dnf install -y"
      elif command -v zypper >/dev/null 2>&1; then
        FAMILY="suse"; PM="zypper"; INSTALL_CMD="sudo zypper install -y"
      elif command -v apk >/dev/null 2>&1; then
        FAMILY="alpine"; PM="apk"; INSTALL_CMD="sudo apk add"
      else
        die "Unsupported or unknown Linux distribution: $DISTRO_NAME ($DISTRO_ID)"
      fi
      ;;
  esac

  info "Detected: $DISTRO_NAME ($FAMILY / $PM)"
}

# ── package collection ────────────────────────────────────────────────────────
collect_packages() {
  [[ -z "${FAMILY:-}" ]] && detect_distro

  local -a pkgs=()
  local base_excluded=0

  case "$PM" in
    apt)
      # Use apt-mark showmanual for explicitly requested packages (excludes most auto/base)
      if command -v apt-mark >/dev/null 2>&1; then
        while IFS= read -r pkg; do
          [[ -n "$pkg" ]] && pkgs+=("$pkg:apt")
        done < <(apt-mark showmanual 2>/dev/null || true)
      else
        # Fallback
        while IFS= read -r pkg; do
          [[ -n "$pkg" ]] && pkgs+=("$pkg:apt")
        done < <(dpkg-query -W -f='${Package}\n' 2>/dev/null | head -200 || true)
      fi
      ;;
    pacman)
      # Explicitly installed
      while IFS= read -r line; do
        pkg=$(awk '{print $1}' <<< "$line")
        [[ -n "$pkg" ]] && pkgs+=("$pkg:pacman")
      done < <(pacman -Qe 2>/dev/null || true)

      # Foreign packages (AUR and manually installed)
      while IFS= read -r line; do
        pkg=$(awk '{print $1}' <<< "$line")
        [[ -n "$pkg" ]] && pkgs+=("$pkg:aur")
      done < <(pacman -Qem 2>/dev/null || true)
      ;;
    dnf)
      # Best effort: explicitly installed via dnf history or list
      if command -v dnf >/dev/null 2>&1; then
        while IFS= read -r pkg; do
          [[ -n "$pkg" ]] && pkgs+=("$pkg:dnf")
        done < <(dnf repoquery --userinstalled 2>/dev/null | cut -d- -f1 | sort -u || dnf list --installed | awk '/^[^ ]/ {print $1}' | cut -d. -f1 || true)
      fi
      ;;
    zypper)
      if command -v zypper >/dev/null 2>&1; then
        while IFS= read -r pkg; do
          [[ -n "$pkg" ]] && pkgs+=("$pkg:zypper")
        done < <(zypper packages --installed-only 2>/dev/null | awk '/^i/ {print $5}' | sort -u || rpm -qa --queryformat '%{NAME}\n' | head -100 || true)
      fi
      ;;
    apk)
      if command -v apk >/dev/null 2>&1; then
        while IFS= read -r pkg; do
          [[ -n "$pkg" ]] && pkgs+=("$pkg:apk")
        done < <(apk info -v 2>/dev/null | cut -d- -f1 | sort -u || true)
      fi
      ;;
  esac

  # Homebrew (works on Linux too)
  if command -v brew >/dev/null 2>&1; then
    while IFS= read -r pkg; do
      [[ -n "$pkg" ]] && pkgs+=("$pkg:brew")
    done < <(brew list --formula 2>/dev/null || true)
    while IFS= read -r pkg; do
      [[ -n "$pkg" ]] && pkgs+=("$pkg:brew")
    done < <(brew list --cask 2>/dev/null || true)
  fi

  # Snap packages (universal)
  if command -v snap >/dev/null 2>&1; then
    while IFS= read -r pkg; do
      [[ -n "$pkg" && "$pkg" != "core" && "$pkg" != "snapd" ]] && pkgs+=("$pkg:snap")
    done < <(snap list 2>/dev/null | awk 'NR>1 {print $1}' || true)
  fi

  # Flatpak packages (universal)
  if command -v flatpak >/dev/null 2>&1; then
    while IFS= read -r pkg; do
      [[ -n "$pkg" ]] && pkgs+=("$pkg:flatpak")
    done < <(flatpak list --app --columns=application 2>/dev/null || true)
  fi

  # Deduplicate and apply excludes
  local -A seen=()
  local -a final=()

  for entry in "${pkgs[@]}"; do
    pkg="${entry%%:*}"
    src="${entry#*:}"

    # Apply EXCLUDES if set (comma separated)
    if [[ -n "${EXCLUDES:-}" ]]; then
      skip=false
      IFS=',' read -ra exarr <<< "$EXCLUDES"
      for ex in "${exarr[@]}"; do
        ex=$(echo "$ex" | tr '[:upper:]' '[:lower:]' | xargs)
        if [[ "$src" == "$ex" || "$ex" == "base" && "$src" == "apt" ]]; then
          skip=true
          break
        fi
      done
      $skip && continue
    fi

    key="$pkg:$src"
    if [[ -z "${seen[$key]:-}" ]]; then
      seen[$key]=1
      final+=("$entry")
    fi
  done

  # Exclude distro base/system packages unless -sp (include system packages)
  if [[ "${INCLUDE_SYSTEM_PACKAGES:-false}" != true ]]; then
    mapfile -t final < <(filter_base_packages "${final[@]}")
  fi

  printf '%s\n' "${final[@]}"
}

# ── sophisticated repo / source availability checks ─────────────────────────
is_available_in_native_repos() {
  local pkg="$1"
  case "$PM" in
    apt)
      apt-cache policy "$pkg" 2>/dev/null | grep -q "Candidate:"
      ;;
    pacman)
      pacman -Si "$pkg" &>/dev/null  # queries official sync databases
      ;;
    dnf)
      dnf list --available "$pkg" &>/dev/null || dnf repoquery "$pkg" &>/dev/null
      ;;
    zypper)
      zypper --quiet search --exact "$pkg" 2>/dev/null | grep -q "^i |^v "
      ;;
    apk)
      apk search -x "$pkg" 2>/dev/null | grep -q "^${pkg}-"
      ;;
    *)
      return 1
      ;;
  esac
}

# Returns list of "source:method" available for this pkg on current system
# source: official, aur, snap, flatpak, brew
get_available_install_options() {
  local pkg="$1"
  local -a opts=()

  # Official / mainline via current PM
  if is_available_in_native_repos "$pkg"; then
    opts+=("official (${PM})")
  fi

  # AUR (Arch specific, use RPC to detect without helper)
  if [[ "$FAMILY" == "arch" ]]; then
    local aur_url="https://aur.archlinux.org/rpc/?v=5&type=info&arg[]=${pkg}"
    local aur_resp=""
    if command -v curl >/dev/null 2>&1; then
      aur_resp=$(curl -s --max-time 5 "$aur_url" 2>/dev/null || true)
    elif command -v wget >/dev/null 2>&1; then
      aur_resp=$(wget -qO- --timeout=5 "$aur_url" 2>/dev/null || true)
    fi
    if echo "$aur_resp" | grep -q '"resultcount":1'; then
      opts+=("AUR (paru)")
    fi
  fi

  # Snap
  if command -v snap >/dev/null 2>&1; then
    if snap info "$pkg" 2>/dev/null | grep -q "^name: ${pkg}"; then
      opts+=("Snap (snap)")
    fi
  fi

  # Flatpak
  if command -v flatpak >/dev/null 2>&1; then
    if flatpak search "$pkg" 2>/dev/null | grep -q "$pkg"; then
      opts+=("Flatpak (flathub)")
    fi
  fi

  # Brew
  if command -v brew >/dev/null 2>&1; then
    if brew search --formulae "^${pkg}$" 2>/dev/null | grep -q "$pkg"; then
      opts+=("Homebrew (brew)")
    fi
  fi

  printf '%s\n' "${opts[@]}"
}

# ── improved base / downstream distro package exclusion ───────────────────────
_is_upstream_distro_id() {
  case "$FAMILY:${DISTRO_ID,,}" in
    arch:arch|debian:debian|fedora:fedora|alpine:alpine) return 0 ;;
    suse:opensuse*|suse:suse|suse:opensuse-tumbleweed|suse:opensuse-leap) return 0 ;;
    fedora:centos|rhel|rocky|almalinux) return 0 ;;
    *) return 1 ;;
  esac
}

_get_downstream_pacman_repos() {
  [[ "$PM" != "pacman" || ! -f /etc/pacman.conf ]] && return 0
  local repo
  while IFS= read -r repo; do
    case "$repo" in
      options|core|extra|multilib|community|testing|core-testing|extra-testing|multilib-testing|community-testing)
        continue
        ;;
      *)
        printf '%s\n' "$repo"
        ;;
    esac
  done < <(grep -E '^\[[^]]+\]' /etc/pacman.conf | tr -d '[]')
}

declare -gA DOWNSTREAM_REPO_PKG_MAP=()

_load_downstream_repo_packages() {
  [[ ${#DOWNSTREAM_REPO_PKG_MAP[@]} -gt 0 ]] && return 0
  local repo pkg
  while IFS= read -r repo; do
    [[ -z "$repo" ]] && continue
    while IFS= read -r pkg; do
      [[ -n "$pkg" ]] && DOWNSTREAM_REPO_PKG_MAP[$pkg]=1
    done < <(pacman -Sl "$repo" 2>/dev/null | awk '{print $2}')
  done < <(_get_downstream_pacman_repos)
}

_package_matches_downstream_name() {
  local pkg="$1"

  _is_upstream_distro_id && return 1

  local id="${DISTRO_ID,,}"

  case "$pkg" in
    "$id"|${id}-*) return 0 ;;
  esac

  case "$id" in
    endeavouros)
      case "$pkg" in eos-*|endeavouros-*) return 0 ;; esac ;;
    manjaro)
      case "$pkg" in manjaro-*|mhwd-*) return 0 ;; esac ;;
    garuda)
      case "$pkg" in garuda-*) return 0 ;; esac ;;
    artix)
      case "$pkg" in artix-*) return 0 ;; esac ;;
    ubuntu)
      case "$pkg" in ubuntu-*|linux-image-*-generic|linux-headers-*-generic|linux-modules-*-generic) return 0 ;; esac ;;
    linuxmint)
      case "$pkg" in mint-*|linuxmint-*|mintmeta-*) return 0 ;; esac ;;
    pop|pop-os)
      case "$pkg" in pop-*|pop-desktop|linux-image-*-generic|linux-headers-*-generic) return 0 ;; esac ;;
    elementary)
      case "$pkg" in elementary-*|pantheon-*) return 0 ;; esac ;;
    kali)
      case "$pkg" in kali-*|kali-defaults) return 0 ;; esac ;;
    rocky)
      case "$pkg" in rocky-*|rocky-release|rocky-repos) return 0 ;; esac ;;
    almalinux)
      case "$pkg" in almalinux-*|almalinux-release) return 0 ;; esac ;;
    centos)
      case "$pkg" in centos-*|centos-release) return 0 ;; esac ;;
    neon)
      case "$pkg" in neon-*|kde-neon-*) return 0 ;; esac ;;
    zorin)
      case "$pkg" in zorin-*|zorinos-*) return 0 ;; esac ;;
  esac

  return 1
}

_package_is_downstream_distro() {
  local pkg="$1"

  if _package_matches_downstream_name "$pkg"; then
    return 0
  fi

  if [[ "$PM" == "pacman" ]]; then
    _load_downstream_repo_packages
    [[ -n "${DOWNSTREAM_REPO_PKG_MAP[$pkg]:-}" ]] && return 0
  fi

  return 1
}

_build_base_package_list() {
  local -a base_list=()

  case "$FAMILY" in
    debian)
      base_list=(base-files bash coreutils debianutils diffutils findutils grep gzip hostname init-system-helpers libc-bin login mount ncurses-base passwd perl-base sed tar util-linux)
      ;;
    arch)
      if command -v pacman >/dev/null 2>&1; then
        mapfile -t base_list < <(pacman -Qg base base-devel 2>/dev/null | awk '{print $2}' | sort -u || true)
      fi
      base_list+=("linux" "linux-firmware" "linux-headers" "systemd" "systemd-sysvcompat" "pacman" "glibc" "filesystem" "archlinux-keyring" "mkinitcpio" "grub")
      ;;
    fedora)
      base_list=(bash coreutils glibc rpm systemd dnf yum fedora-release kernel kernel-core)
      ;;
    suse)
      base_list=(bash coreutils glibc systemd zypper suse-release kernel-default)
      ;;
    alpine)
      base_list=(alpine-baselayout busybox apk-tools linux-lts linux-firmware)
      ;;
    *)
      base_list=()
      ;;
  esac

  local user_excludes="$HOME/.config/grabbit/base-excludes.${FAMILY:-unknown}"
  if [[ -f "$user_excludes" ]]; then
    while IFS= read -r b || [[ -n "$b" ]]; do
      [[ -z "$b" || "$b" == \#* ]] && continue
      base_list+=("$b")
    done < "$user_excludes"
  fi

  printf '%s\n' "${base_list[@]}"
}

_package_is_base() {
  local pkg="$1"
  local -a base_list=()
  local base

  mapfile -t base_list < <(_build_base_package_list)

  for base in "${base_list[@]}"; do
    [[ "$pkg" == "$base" ]] && return 0
  done

  case "$FAMILY" in
    arch)
      case "$pkg" in
        linux|linux-*|linux-firmware|linux-firmware-*|linux-headers|linux-headers-*|\
        systemd|systemd-*|mkinitcpio|mkinitcpio-*|grub|grub-*|archlinux-*|\
        pacman|pacman-*|glibc|filesystem|base|base-*|bash|coreutils|\
        systemd-sysvcompat|kmod|hwdata|iana-etc|tzdata|licenses|pciutils|usbutils|\
        inetutils|iputils|ca-certificates|ca-certificates-*|openssl|openssl-*)
          return 0
          ;;
      esac
      ;;
    debian)
      case "$pkg" in
        linux-*|libc6|systemd|systemd-*|dpkg|dpkg-*|apt|apt-*|ubuntu-*|debian-*|\
        perl-base|ncurses-base|base-files|base-passwd)
          return 0
          ;;
      esac
      ;;
    fedora)
      case "$pkg" in
        kernel|kernel-*|systemd|systemd-*|glibc|bash|coreutils|dnf|dnf-*|rpm|rpm-*|\
        fedora-release|fedora-release-*)
          return 0
          ;;
      esac
      ;;
    suse)
      case "$pkg" in
        kernel-default|kernel-*|systemd|systemd-*|glibc|bash|coreutils|zypper|zypper-*)
          return 0
          ;;
      esac
      ;;
    alpine)
      case "$pkg" in
        linux-*|linux-firmware|linux-firmware-*|busybox|alpine-baselayout|apk-tools|musl|musl-*)
          return 0
          ;;
      esac
      ;;
  esac

  _package_is_downstream_distro "$pkg" && return 0

  return 1
}

filter_base_packages() {
  local -a input_pkgs=("$@")
  local -a output=()
  local entry pkg src

  for entry in "${input_pkgs[@]}"; do
    pkg="${entry%%:*}"
    src="${entry#*:}"

    # User-added external sources are always kept
    case "$src" in
      aur|brew|snap|flatpak) output+=("$entry"); continue ;;
    esac

    if _package_is_base "$pkg"; then
      continue
    fi
    output+=("$entry")
  done

  printf '%s\n' "${output[@]}"
}

# ── ensure helper tools ───────────────────────────────────────────────────────
ensure_helper() {
  local helper="$1"
  case "$helper" in
    paru)
      if ! command -v paru >/dev/null 2>&1; then
        if [[ "$FAMILY" != "arch" ]]; then
          warn "paru is only available on Arch-based systems. Skipping AUR packages or install manually."
          return 1
        fi
        step "Installing paru (AUR helper)"
        sudo pacman -S --needed --noconfirm base-devel git
        local tmpdir
        tmpdir=$(mktemp -d)
        git clone https://aur.archlinux.org/paru.git "$tmpdir/paru"
        (cd "$tmpdir/paru" && makepkg -si --noconfirm)
        rm -rf "$tmpdir"
        ok "paru installed"
      else
        info "paru already present"
      fi
      ;;
    brew)
      if ! command -v brew >/dev/null 2>&1; then
        step "Installing Homebrew"
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        # shellcheck disable=SC2016
        if [[ -d /home/linuxbrew/.linuxbrew ]]; then
          eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
        fi
        ok "Homebrew installed"
      fi
      ;;
    snap)
      if ! command -v snap >/dev/null 2>&1; then
        step "Ensuring snapd is installed (via native PM)"
        case "$PM" in
          apt) sudo apt update && sudo apt install -y snapd ;;
          pacman) sudo pacman -S --needed --noconfirm snapd ;;
          dnf) sudo dnf install -y snapd ;;
          zypper) sudo zypper install -y snapd ;;
          *) warn "Please install snapd manually for this distro" ;;
        esac
        # enable service if possible
        sudo systemctl enable --now snapd.socket || true
      fi
      ;;
    flatpak)
      if ! command -v flatpak >/dev/null 2>&1; then
        step "Ensuring flatpak is installed (via native PM)"
        case "$PM" in
          apt) sudo apt update && sudo apt install -y flatpak ;;
          pacman) sudo pacman -S --needed --noconfirm flatpak ;;
          dnf) sudo dnf install -y flatpak ;;
          zypper) sudo zypper install -y flatpak ;;
          *) warn "Please install flatpak manually for this distro" ;;
        esac
      fi
      ;;
    *)
      warn "Unknown helper: $helper"
      ;;
  esac
}

# ── save command ──────────────────────────────────────────────────────────────
do_save() {
  local outfile="$1"

  detect_distro

  if [[ "${INCLUDE_SYSTEM_PACKAGES:-false}" == true ]]; then
    step "Collecting installed packages (including distro/system packages)"
  else
    step "Collecting user-added packages (excluding distro base/system packages)"
  fi

  local -a collected
  mapfile -t collected < <(collect_packages)

  if [[ ${#collected[@]} -eq 0 ]]; then
    warn "No additional packages detected."
    exit 0
  fi

  ok "Found ${#collected[@]} package(s)"

  step "Writing grabbit file: $outfile"

  {
    echo "# GRABBIT v${GRABBIT_VERSION}"
    echo "# Created: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "# ORIG_DISTRO=$DISTRO_ID"
    echo "# ORIG_FAMILY=$FAMILY"
    echo "# ORIG_PM=$PM"
    echo "# ORIG_DISTRO_NAME=\"$DISTRO_NAME\""
    echo ""
    echo "PKG_LIST_START"
    for entry in "${collected[@]}"; do
      echo "PKG $entry"
    done
    echo "PKG_LIST_END"
  } > "$outfile"

  ok "Saved grabbit file with ${#collected[@]} entries"
  info "You can now transfer $outfile to another machine and run: grabbit load $outfile"
}

# ── load / transpose logic ────────────────────────────────────────────────────
get_install_command() {
  local pkg="$1"
  local src="$2"
  local orig_family="$3"

  # Current distro info already in FAMILY / PM / INSTALL_CMD globals

  # Simple name mappings for common cross-distro cases (extend as needed)
  declare -A PKG_MAP
  PKG_MAP["build-essential"]="base-devel"
  PKG_MAP["base-devel"]="build-essential"
  PKG_MAP["python3-dev"]="python"
  # etc. Use original if no map or reverse lookup
  local mapped_pkg="$pkg"
  if [[ -n "${PKG_MAP[$pkg]:-}" && "$FAMILY" != "$orig_family" ]]; then
    mapped_pkg="${PKG_MAP[$pkg]}"
  fi

  case "$src" in
    apt)
      if [[ "$FAMILY" == "debian" ]]; then
        echo "sudo apt update && sudo apt install -y $mapped_pkg"
      else
        # transpose
        echo "${INSTALL_CMD} $mapped_pkg"
      fi
      ;;
    pacman|dnf|zypper|apk)
      if [[ "$FAMILY" == "arch" || "$FAMILY" == "fedora" || "$FAMILY" == "suse" || "$FAMILY" == "alpine" ]]; then
        echo "${INSTALL_CMD} $pkg"
      else
        # transpose to current
        echo "${INSTALL_CMD} $pkg"
      fi
      ;;
    aur)
      if [[ "$FAMILY" == "arch" ]]; then
        echo "paru -S --needed --noconfirm $pkg"
      else
        echo "# SKIP: AUR package '$pkg' cannot be installed on $FAMILY"
      fi
      ;;
    brew)
      echo "brew install $pkg"
      ;;
    snap)
      echo "sudo snap install $pkg"
      ;;
    flatpak)
      echo "flatpak install -y flathub $pkg"
      ;;
    *)
      echo "${INSTALL_CMD} $pkg"
      ;;
  esac
}

do_load() {
  local infile="$1"

  [[ -f "$infile" ]] || die "File not found: $infile"

  detect_distro

  step "Reading grabbit file: $infile"

  # Parse header
  local orig_distro orig_family orig_pm
  orig_distro=$(grep '^# ORIG_DISTRO=' "$infile" | cut -d= -f2 || echo unknown)
  orig_family=$(grep '^# ORIG_FAMILY=' "$infile" | cut -d= -f2 || echo unknown)
  orig_pm=$(grep '^# ORIG_PM=' "$infile" | cut -d= -f2 || echo unknown)

  info "Original file created on: $orig_distro ($orig_family / $orig_pm)"
  info "Current system: $DISTRO_ID ($FAMILY / $PM)"

  # Extract packages
  local -a packages=()
  local in_list=false
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "PKG_LIST_START" ]]; then
      in_list=true
      continue
    fi
    if [[ "$line" == "PKG_LIST_END" ]]; then
      break
    fi
    if $in_list && [[ "$line" == PKG* ]]; then
      # PKG name:src
      entry=${line#PKG }
      packages+=("$entry")
    fi
  done < "$infile"

  if [[ ${#packages[@]} -eq 0 ]]; then
    warn "No packages found in file."
    exit 0
  fi

  ok "Loaded ${#packages[@]} package entries from file"

  # Apply excludes if -x was used with types
  local -a to_install=()
  for entry in "${packages[@]}"; do
    pkg="${entry%%:*}"
    src="${entry#*:}"

    if [[ -n "${EXCLUDES:-}" ]]; then
      skip=false
      IFS=',' read -ra exarr <<< "$EXCLUDES"
      for ex in "${exarr[@]}"; do
        ex=$(echo "$ex" | tr '[:upper:]' '[:lower:]' | xargs)
        if [[ "$src" == "$ex" ]]; then
          skip=true
          info "Skipping (excluded by -x): $pkg ($src)"
          break
        fi
      done
      $skip && continue
    fi

    to_install+=("$entry")
  done

  if [[ ${#to_install[@]} -eq 0 ]]; then
    warn "Nothing left to install after filters."
    exit 0
  fi

  step "Ensuring required package helpers are present"

  local need_paru=false
  local need_brew=false
  local need_snap=false
  local need_flatpak=false

  for entry in "${to_install[@]}"; do
    src="${entry#*:}"
    case "$src" in
      aur) need_paru=true ;;
      brew) need_brew=true ;;
      snap) need_snap=true ;;
      flatpak) need_flatpak=true ;;
    esac
  done

  if $need_paru; then
    ensure_helper paru || warn "paru installation failed or not possible"
  fi
  if $need_brew; then
    ensure_helper brew || warn "Homebrew installation failed or not possible"
  fi
  if $need_snap; then
    ensure_helper snap || warn "snapd installation may have issues"
  fi
  if $need_flatpak; then
    ensure_helper flatpak || warn "flatpak installation may have issues"
  fi

  step "Installing packages (transposing commands as needed)"

  local installed=0 failed=0

  for entry in "${to_install[@]}"; do
    pkg="${entry%%:*}"
    src="${entry#*:}"

    # Check if already installed (best effort)
    case "$PM" in
      apt)    if dpkg -l "$pkg" &>/dev/null; then info "Already installed: $pkg"; continue; fi ;;
      pacman) if pacman -Q "$pkg" &>/dev/null; then info "Already installed: $pkg"; continue; fi ;;
      dnf)    if rpm -q "$pkg" &>/dev/null; then info "Already installed: $pkg"; continue; fi ;;
      zypper) if rpm -q "$pkg" &>/dev/null; then info "Already installed: $pkg"; continue; fi ;;
      apk)    if apk info -e "$pkg" &>/dev/null; then info "Already installed: $pkg"; continue; fi ;;
    esac
    # also check snap/flatpak
    if [[ "$src" == "snap" ]] && command -v snap >/dev/null && snap list "$pkg" &>/dev/null; then info "Already installed: $pkg"; continue; fi
    if [[ "$src" == "flatpak" ]] && command -v flatpak >/dev/null && flatpak info "$pkg" &>/dev/null; then info "Already installed: $pkg"; continue; fi

    # Sophisticated multi-source detection
    mapfile -t options < <(get_available_install_options "$pkg")

    local chosen_method=""
    local chosen_label=""

    if [[ ${#options[@]} -eq 0 ]]; then
      # No matches found, fall back to original src logic
      chosen_method="$src"
      info "No current-repo matches found for '$pkg' (original source: $src). Using transposed original method."
    elif [[ ${#options[@]} -eq 1 ]]; then
      chosen_method="${options[0]}"
      info "Single option for '$pkg': ${options[0]}"
    else
      # Multiple options: prompt if interactive
      if [[ -t 0 ]]; then
        step "Multiple installation options found for '$pkg' (original source was: $src)"
        chosen_label=$(_pick_option "Select option:" "${options[@]}")
        chosen_method="$chosen_label"
        info "User selected: $chosen_method for $pkg"
      else
        # Non-interactive: prefer official/native if present, else first
        chosen_method="${options[0]}"
        for opt in "${options[@]}"; do
          if [[ "$opt" == official* ]]; then
            chosen_method="$opt"
            break
          fi
        done
        info "Non-interactive: auto-selected $chosen_method for '$pkg' (multiple available)"
      fi
    fi

    # Map chosen_method (human label) to a src-like for get_install_command
    local effective_src="$src"
    case "$chosen_method" in
      official*)
        effective_src="$PM"  # will use native INSTALL_CMD
        ;;
      AUR*)
        effective_src="aur"
        ;;
      Snap*)
        effective_src="snap"
        ;;
      Flatpak*)
        effective_src="flatpak"
        ;;
      Homebrew*)
        effective_src="brew"
        ;;
      *)
        effective_src="$chosen_method"  # fallback
        ;;
    esac

    # Ensure helper for the chosen method if needed (lazy)
    case "$chosen_method" in
      AUR*)
        ensure_helper paru || { warn "Cannot use AUR for $pkg"; ((failed++)) || true; continue; }
        ;;
      Homebrew*)
        ensure_helper brew || { warn "Cannot use brew for $pkg"; ((failed++)) || true; continue; }
        ;;
      Snap*)
        ensure_helper snap || { warn "Cannot use snap for $pkg"; ((failed++)) || true; continue; }
        ;;
      Flatpak*)
        ensure_helper flatpak || { warn "Cannot use flatpak for $pkg"; ((failed++)) || true; continue; }
        ;;
    esac

    local cmd
    cmd=$(get_install_command "$pkg" "$effective_src" "$orig_family")

    if [[ "$cmd" == "# SKIP"* ]]; then
      warn "$cmd"
      ((failed++)) || true
      continue
    fi

    info "Installing $pkg (chose $chosen_method) → $cmd"
    if eval "$cmd"; then
      ok "Installed: $pkg"
      ((installed++)) || true
    else
      warn "Failed to install: $pkg"
      ((failed++)) || true
    fi
  done

  echo ""
  if [[ $failed -eq 0 ]]; then
    ok "All packages processed successfully ($installed installed or already present)"
  else
    warn "$installed installed, $failed failed"
  fi
}

# ── global install (CLI + GUI + distro deps) ──────────────────────────────────
GRABBIT_GITHUB_RAW="${GRABBIT_GITHUB_RAW:-https://raw.githubusercontent.com/Arrowstorm-Technologies-LLC/grabbit/main}"

_grabbit_install_dir() {
  dirname "$(readlink -f "${BASH_SOURCE[0]}")"
}

_run_global_installer() {
  local bindir="$(_grabbit_install_dir)" installer tmp

  for installer in "$bindir/install.sh" "$HOME/.local/bin/install.sh" "${bindir%/*}/install.sh"; do
    if [[ -f "$installer" ]]; then
      exec bash "$installer" "$@"
    fi
  done

  tmp="$(mktemp)"
  if ! curl -fsSL "$GRABBIT_GITHUB_RAW/install.sh" -o "$tmp"; then
    die "Could not download install.sh from $GRABBIT_GITHUB_RAW"
  fi
  chmod +x "$tmp"
  GRABBIT_SOURCE_DIR="$bindir" exec bash "$tmp" "$@"
}

_maybe_complete_global_install() {
  local bindir="$(_grabbit_install_dir)"
  local rack_dir="${RACK_DIR:-$HOME/.local/bin}"

  case "$bindir" in
    "$HOME/.local/bin"|"$rack_dir") ;;
    *) return 0 ;;
  esac

  if [[ -f "$bindir/grabbit-gui" && -f "$bindir/grabbit_gui.py" ]]; then
    return 0
  fi

  step "Completing grabbit global install (GUI + dependencies)"
  _run_global_installer
}

do_global_install() {
  _run_global_installer "$@"
}

# ── main ──────────────────────────────────────────────────────────────────────
main() {
  EXCLUDES=""
  INCLUDE_SYSTEM_PACKAGES=false

  if [[ "${1:-}" == "install" ]]; then
    shift
    do_global_install "$@"
    return
  fi

  _maybe_complete_global_install

  while [[ $# -gt 0 && "$1" == -* ]]; do
    case "$1" in
      -sp)
        INCLUDE_SYSTEM_PACKAGES=true
        shift
        ;;
      -x)
        shift
        if [[ $# -gt 0 && "$1" =~ ^[a-zA-Z,]+$ && "$1" != "save" && "$1" != "load" ]]; then
          EXCLUDES="$1"
          shift
        fi
        ;;
      -h|--help|help)
        usage
        ;;
      *)
        break
        ;;
    esac
  done

  local cmd="${1:-}"
  local path="${2:-}"

  case "$cmd" in
    save)
      [[ -z "$path" ]] && usage
      do_save "$path"
      ;;
    load)
      [[ -z "$path" ]] && usage
      do_load "$path"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      die "Unknown command: $cmd. Use 'grabbit' for usage."
      ;;
  esac
}

main "$@"