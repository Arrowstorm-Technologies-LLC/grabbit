#!/usr/bin/env bash
#
# grabbit-gui launcher
# Allows running as: grabbit-gui [optional.grab-file]
#

# Resolve the directory of this script (works with symlinks)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

# Prefer the Python GUI in the same directory
GUI_SCRIPT="$SCRIPT_DIR/grabbit_gui.py"

if [ ! -f "$GUI_SCRIPT" ]; then
    echo "Error: Could not find grabbit_gui.py next to this launcher." >&2
    exit 1
fi

# Prefer a Python that can import tkinter (Homebrew Python often lacks Tk)
PYTHON=""
for candidate in python3 /usr/bin/python3; do
    if command -v "$candidate" >/dev/null 2>&1 \
        && "$candidate" -c "import tkinter" >/dev/null 2>&1; then
        PYTHON="$candidate"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    echo "Error: No Python with tkinter found. Install Tk for your distro, e.g.:" >&2
    echo "  Arch:   sudo pacman -S tk" >&2
    echo "  Debian: sudo apt install python3-tk" >&2
    echo "  Fedora: sudo dnf install python3-tkinter" >&2
    exit 1
fi

exec "$PYTHON" "$GUI_SCRIPT" "$@"